>>>>>>> d9e7f53 (feat: Improve error handling with custom Firestore utility)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isServerTimestamp(field) {
      return field == request.time;
    }

    // --- VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.keys().hasAll(['email', 'displayName', 'role', 'uid', 'createdAt', 'lastLogin', 'biometricsEnabled']) &&
             data.keys().size() == 7;
    }

    function isValidEntry(data) {
      return data.ownerId == request.auth.uid &&
             data.titleEncrypted is string && data.titleEncrypted.size() <= 1000 &&
             data.contentEncrypted is string && data.contentEncrypted.size() <= 100000 &&
             data.category is string && data.category.size() <= 50 &&
             data.securityLevel is string && data.securityLevel.size() <= 20 &&
             data.keys().hasAll(['ownerId', 'titleEncrypted', 'contentEncrypted', 'createdAt', 'updatedAt', 'category', 'securityLevel']) &&
             data.keys().size() == 7;
    }

    function isValidActivityLog(data) {
      return data.userId == request.auth.uid &&
             data.action is string && data.action.size() <= 100 &&
             data.resource is string && data.resource.size() <= 255 &&
             data.status is string && data.status.size() <= 20;
    }

    // --- COLLECTIONS ---

    // 1. User Profiles
    match /users/{userId} {
