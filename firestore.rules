rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isServerTimestamp(field) {
      return field == request.time;
    }

    // --- VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.uid == request.auth.uid &&
             data.keys().hasAll(['email', 'displayName', 'role', 'uid', 'createdAt', 'lastLogin', 'biometricsEnabled']);
     }

    function isValidEntry(data) {
      return data.ownerId == request.auth.uid &&
             data.titleEncrypted is string && data.titleEncrypted.size() <= 1000 &&
             data.contentEncrypted is string && data.contentEncrypted.size() <= 100000 &&
             data.categoryEncrypted is string && data.categoryEncrypted.size() <= 500 &&
             data.securityLevelEncrypted is string && data.securityLevelEncrypted.size() <= 500 &&
             data.iv is string && data.iv.size() <= 128 &&
             data.salt is string && data.salt.size() <= 128;
    }

    // Accept server-side timestamps (or client-supplied timestamps) for created/updated fields.
    function hasValidTimestamps(data) {
      return (data.createdAt is timestamp) && (data.updatedAt is timestamp);
    }

    function isValidActivityLog(data) {
      return data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.action is string && data.action.size() <= 100 &&
             data.resource is string && data.resource.size() <= 255 &&
             data.status is string && data.status.size() <= 20 &&
             data.keys().hasAll(['userId', 'userEmail', 'action', 'resource', 'timestamp', 'status']) &&
             data.keys().size() == 6;
    }

    // --- COLLECTIONS ---

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user' && isServerTimestamp(incoming().createdAt) && isServerTimestamp(incoming().lastLogin);
      allow update: if (
                      isOwner(userId) && isValidUser(incoming()) &&
                      incoming().role == existing().role &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'lastLogin', 'biometricsEnabled', 'verifierPayload', 'verifierSalt', 'verifierIv'])
                    ) || (
                      isAdmin() && isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      incoming().displayName == existing().displayName &&
                      incoming().biometricsEnabled == existing().biometricsEnabled &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().lastLogin == existing().lastLogin &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['role'])
                    );
    }

    // 2. Diary Entries
    match /entries/{entryId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn();
      // Allow creation when the entry is valid and timestamps are present (serverTimestamp() resolves to a timestamp).
      allow create: if isSignedIn() && isValidEntry(incoming()) && hasValidTimestamps(incoming());
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid &&
                    isValidEntry(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    isServerTimestamp(incoming().updatedAt) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['titleEncrypted', 'contentEncrypted', 'updatedAt', 'category', 'securityLevel', 'iv', 'salt']);
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    // 3. Activity Logs
    match /activityLogs/{logId} {
      allow create: if isSignedIn() && isValidActivityLog(incoming()) && isServerTimestamp(incoming().timestamp);
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 4. Security Logs
    match /securityLogs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // 5. Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    incoming().title == existing().title &&
                    incoming().message == existing().message &&
                    incoming().timestamp == existing().timestamp &&
                    incoming().priority == existing().priority &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
